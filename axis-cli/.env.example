# ========================================
# AXIS CLI Configuration
# ========================================
# Copy this file to .env and fill in your values

# Server Connection
AXIS_SERVER_URL=http://localhost:3000/api/axis

# Client Identity
AXIS_ACTOR_ID=00000000000000000000000000000001
AXIS_PRIVATE_KEY=your_ed25519_private_key_hex

# Proof Settings
AXIS_PROOF_TYPE=1
AXIS_CAPSULE_ID=

# CLI Settings
AXIS_OUTPUT_FORMAT=json
AXIS_VERBOSE=false
AXIS_TIMEOUT_MS=30000

# File Operations
AXIS_UPLOAD_CHUNK_SIZE=65536
AXIS_DOWNLOAD_PATH=./downloads

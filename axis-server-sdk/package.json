{
  "name": "@nextera.one/axis-server-sdk",
  "version": "2.3.0",
  "description": "Axis Protocol server-side SDK — decorators, interfaces, and routing primitives for building Axis handlers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./bin/generate-keys": {
      "types": "./dist/bin/generate-keys.d.ts",
      "import": "./dist/bin/generate-keys.mjs",
      "require": "./dist/bin/generate-keys.js"
    },
    "./sensors": {
      "types": "./dist/sensors/index.d.ts",
      "import": "./dist/sensors/index.mjs",
      "require": "./dist/sensors/index.js"
    },
    "./timeline": {
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.mjs",
      "require": "./dist/timeline/index.js"
    },
    "./idel": {
      "types": "./dist/idel/index.d.ts",
      "import": "./dist/idel/index.mjs",
      "require": "./dist/idel/index.js"
    },
    "./needle": {
      "types": "./dist/needle/index.d.ts",
      "import": "./dist/needle/index.mjs",
      "require": "./dist/needle/index.js"
    },
    "./cce": {
      "types": "./dist/cce/index.d.ts",
      "import": "./dist/cce/index.mjs",
      "require": "./dist/cce/index.js"
    }
  },
  "bin": {
    "axis-generate-keys": "dist/bin/generate-keys.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run build && node --test test/*.test.js",
    "prepublishOnly": "tsup",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digital-pages-co/axis.git",
    "directory": "axis-server-sdk"
  },
  "homepage": "https://axisprotocol.io",
  "bugs": {
    "url": "https://github.com/digital-pages-co/axis/issues"
  },
  "keywords": [
    "axis",
    "protocol",
    "typescript",
    "server",
    "sdk",
    "handler",
    "decorator",
    "intent",
    "router",
    "binary"
  ],
  "author": "NextEra.One",
  "license": "Apache-2.0",
  "type": "commonjs",
  "peerDependencies": {
    "reflect-metadata": ">=0.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild-plugin-tsc": "^0.6.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "tweetnacl": "^1.0.3"
  },
  "dependencies": {
    "@nextera.one/axis-protocol": "^1.1.1",
    "@noble/hashes": "^2.2.0",
    "zod": "^4.4.3"
  }
}

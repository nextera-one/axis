{
  "name": "@nextera.one/axis-server-sdk",
  "version": "2.1.4",
  "description": "Axis Protocol server-side SDK — decorators, interfaces, and routing primitives for building Axis handlers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./bin/generate-keys": {
      "types": "./dist/bin/generate-keys.d.ts",
      "import": "./dist/bin/generate-keys.mjs",
      "require": "./dist/bin/generate-keys.js"
    }
  },
  "bin": {
    "axis-generate-keys": "dist/bin/generate-keys.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digital-pages-co/axis.git",
    "directory": "axis-server-sdk"
  },
  "homepage": "https://axisprotocol.io",
  "bugs": {
    "url": "https://github.com/digital-pages-co/axis/issues"
  },
  "keywords": [
    "axis",
    "protocol",
    "typescript",
    "server",
    "sdk",
    "handler",
    "decorator",
    "intent",
    "router",
    "binary"
  ],
  "author": "NextEra.One",
  "license": "Apache-2.0",
  "type": "commonjs",
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/config": ">=3.0.0",
    "@nestjs/core": ">=10.0.0",
    "reflect-metadata": ">=0.1.12"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "esbuild-plugin-tsc": "^0.5.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nextera.one/axis-protocol": "^1.0.0",
    "@noble/hashes": "^2.0.1",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  }
}

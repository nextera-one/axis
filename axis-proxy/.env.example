# ========================================
# AXIS Proxy Configuration
# ========================================
# Copy this file to .env and fill in your values

# Server Settings
AXIS_PROXY_PORT=7777

# Backend Connection
AXIS_BACKEND_URL=http://localhost:3000/api/axis

# Proxy Mode: translate | passthrough | hybrid
AXIS_PROXY_MODE=hybrid

# Request Signing
AXIS_SIGN_REQUESTS=false
AXIS_SIGNING_KEY=your_ed25519_private_key_hex
AXIS_PROXY_ACTOR_ID=proxy-00000001

# Rate Limiting
AXIS_RATE_LIMIT=100

# Logging
AXIS_DEBUG=false
LOG_LEVEL=info

# CORS Settings
CORS_ORIGIN=*
CORS_METHODS=GET,POST,OPTIONS

# Timeouts
AXIS_REQUEST_TIMEOUT_MS=30000
AXIS_KEEPALIVE_TIMEOUT_MS=5000

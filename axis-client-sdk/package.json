{
  "name": "@nextera.one/axis-client-sdk",
  "version": "1.5.0",
  "description": "Official TypeScript/JavaScript client SDK for the AXIS Protocol v1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digital-pages-co/axis.git",
    "directory": "axis-client-sdk"
  },
  "homepage": "https://axisprotocol.io",
  "bugs": {
    "url": "https://github.com/digital-pages-co/axis/issues"
  },
  "keywords": [
    "axis",
    "protocol",
    "typescript",
    "client",
    "sdk",
    "binary",
    "ed25519",
    "signature",
    "frame",
    "tlv"
  ],
  "author": "NextEra.One",
  "license": "Apache-2.0",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "fast-check": "^4.5.2",
    "prettier": "^3.7.4",
    "sodium-native": "^5.0.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "axios": "^1.13.2",
    "ulid": "^3.0.2",
    "uuid": "^11.1.0"
  }
}
